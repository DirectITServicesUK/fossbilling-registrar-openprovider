{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}
{% import 'macro_functions.html.twig' as mf %}
{% set active_menu = 'openprovider' %}

{% block meta_title %}DNS Zones{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">{{ 'DNS Zones'|trans }}</h3>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createZoneModal">
            {{ 'Create Zone'|trans }}
        </button>
    </div>
    <div class="card-body">
        <div class="mb-3">
            <div class="input-group" style="max-width: 400px;">
                <input type="text" class="form-control form-control-sm" id="zone-search" placeholder="{{ 'Search zones...'|trans }}">
                <button class="btn btn-sm btn-outline-secondary" type="button" id="zone-search-btn">{{ 'Search'|trans }}</button>
            </div>
        </div>
        <div class="table-responsive">
            <table class="table table-hover table-sm">
                <thead>
                    <tr>
                        <th>{{ 'Zone'|trans }}</th>
                        <th>{{ 'Type'|trans }}</th>
                        <th>{{ 'Records'|trans }}</th>
                        <th>{{ 'DNSSEC'|trans }}</th>
                        <th>{{ 'Provider'|trans }}</th>
                        <th class="text-end">{{ 'Actions'|trans }}</th>
                    </tr>
                </thead>
                <tbody id="zone-list">
                    <tr><td colspan="6" class="text-center text-muted">{{ 'Loading...'|trans }}</td></tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Create Zone Modal -->
<div class="modal fade" id="createZoneModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Create DNS Zone'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">{{ 'Domain Name'|trans }}</label>
                    <div class="input-group">
                        <input type="text" class="form-control" id="new-zone-domain" placeholder="example">
                        <span class="input-group-text">.</span>
                        <input type="text" class="form-control" id="new-zone-extension" placeholder="co.uk">
                    </div>
                </div>
                <div class="form-check mb-3">
                    <input class="form-check-input" type="checkbox" id="new-zone-dnssec">
                    <label class="form-check-label" for="new-zone-dnssec">{{ 'Enable DNSSEC'|trans }}</label>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="button" class="btn btn-primary" id="create-zone-btn">{{ 'Create'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    loadZones();

    document.getElementById('zone-search-btn').addEventListener('click', function() {
        loadZones(document.getElementById('zone-search').value);
    });

    document.getElementById('zone-search').addEventListener('keypress', function(e) {
        if (e.key === 'Enter') loadZones(this.value);
    });

    document.getElementById('create-zone-btn').addEventListener('click', function() {
        var domain = document.getElementById('new-zone-domain').value.trim();
        var ext = document.getElementById('new-zone-extension').value.trim().replace(/^\./, '');
        var secured = document.getElementById('new-zone-dnssec').checked;

        if (!domain || !ext) {
            FOSSBilling.message('Please enter a domain name and extension.', 'error');
            return;
        }

        API.admin.post('openprovider/zone_create', {
            domain_name: domain,
            extension: ext,
            secured: secured
        }, function(result) {
            FOSSBilling.message('Zone created successfully.');
            bootstrap.Modal.getInstance(document.getElementById('createZoneModal')).hide();
            document.getElementById('new-zone-domain').value = '';
            document.getElementById('new-zone-extension').value = '';
            loadZones();
        });
    });
});

function loadZones(search) {
    var params = {};
    if (search) params.name_pattern = '*' + search + '*';

    API.admin.post('openprovider/zone_get_list', params, function(result) {
        var tbody = document.getElementById('zone-list');
        var zones = result.results || [];

        if (zones.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">No zones found.</td></tr>';
            return;
        }

        tbody.innerHTML = '';
        zones.forEach(function(zone) {
            var name = zone.name || (zone.domain ? zone.domain.name + '.' + zone.domain.extension : 'Unknown');
            var tr = document.createElement('tr');
            tr.innerHTML =
                '<td><a href="' + "{{ ''|alink }}" + '/openprovider/zone/' + name + '">' + name + '</a></td>' +
                '<td>' + (zone.type || '-') + '</td>' +
                '<td>' + (zone.records ? zone.records.length : '-') + '</td>' +
                '<td>' + (zone.is_secured ? '<span class="badge bg-success">Yes</span>' : '<span class="badge bg-secondary">No</span>') + '</td>' +
                '<td>' + (zone.provider || 'Standard') + '</td>' +
                '<td class="text-end">' +
                    '<a href="' + "{{ ''|alink }}" + '/openprovider/zone/' + name + '" class="btn btn-sm btn-outline-primary">Manage</a> ' +
                    '<button class="btn btn-sm btn-outline-danger delete-zone-btn" data-zone="' + name + '">Delete</button>' +
                '</td>';
            tbody.appendChild(tr);
        });

        document.querySelectorAll('.delete-zone-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                if (confirm('Delete zone ' + this.dataset.zone + '? This cannot be undone.')) {
                    API.admin.post('openprovider/zone_delete', {name: this.dataset.zone}, function() {
                        FOSSBilling.message('Zone deleted.');
                        loadZones();
                    });
                }
            });
        });
    });
}
</script>
{% endblock %}
