{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}
{% import 'macro_functions.html.twig' as mf %}
{% set active_menu = 'openprovider' %}

{% block meta_title %}DNS Templates{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h3 class="card-title">{{ 'DNS Templates'|trans }}</h3>
        <button class="btn btn-primary btn-sm" data-bs-toggle="modal" data-bs-target="#createTemplateModal">
            {{ 'Create Template'|trans }}
        </button>
    </div>
    <div class="card-body">
        <div id="template-list">
            <p class="text-muted">{{ 'Loading...'|trans }}</p>
        </div>
    </div>
</div>

<!-- Create Template Modal -->
<div class="modal fade" id="createTemplateModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">{{ 'Create DNS Template'|trans }}</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label">{{ 'Template Name'|trans }}</label>
                    <input type="text" class="form-control" id="tpl-name" placeholder="{{ 'e.g. Standard Web Hosting'|trans }}">
                </div>
                <h6>{{ 'Records'|trans }}</h6>
                <div id="tpl-records">
                    <div class="row g-2 mb-2 tpl-record-row">
                        <div class="col-3"><input type="text" class="form-control form-control-sm tpl-rec-name" placeholder="Name (e.g. www)"></div>
                        <div class="col-2">
                            <select class="form-select form-select-sm tpl-rec-type">
                                <option>A</option><option>AAAA</option><option>CNAME</option><option>MX</option><option>TXT</option><option>NS</option><option>SRV</option><option>CAA</option>
                            </select>
                        </div>
                        <div class="col-3"><input type="text" class="form-control form-control-sm tpl-rec-value" placeholder="Value"></div>
                        <div class="col-2"><input type="number" class="form-control form-control-sm tpl-rec-ttl" value="3600" placeholder="TTL"></div>
                        <div class="col-1"><input type="number" class="form-control form-control-sm tpl-rec-prio" value="0" placeholder="Prio"></div>
                        <div class="col-1"><button type="button" class="btn btn-sm btn-outline-danger remove-tpl-row">X</button></div>
                    </div>
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary mt-2" id="add-tpl-record">{{ '+ Add Record'|trans }}</button>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                <button type="button" class="btn btn-primary" id="create-template-btn">{{ 'Create Template'|trans }}</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    loadTemplates();

    // Add record row to template form
    document.getElementById('add-tpl-record').addEventListener('click', function() {
        var container = document.getElementById('tpl-records');
        var row = container.querySelector('.tpl-record-row').cloneNode(true);
        row.querySelectorAll('input').forEach(function(input) {
            if (input.classList.contains('tpl-rec-ttl')) { input.value = '3600'; }
            else if (input.classList.contains('tpl-rec-prio')) { input.value = '0'; }
            else { input.value = ''; }
        });
        container.appendChild(row);
        attachRemoveHandlers();
    });

    attachRemoveHandlers();

    // Create template
    document.getElementById('create-template-btn').addEventListener('click', function() {
        var name = document.getElementById('tpl-name').value.trim();
        if (!name) {
            FOSSBilling.message('Template name is required.', 'error');
            return;
        }

        var records = [];
        document.querySelectorAll('.tpl-record-row').forEach(function(row) {
            var value = row.querySelector('.tpl-rec-value').value.trim();
            if (value) {
                records.push({
                    name: row.querySelector('.tpl-rec-name').value.trim(),
                    type: row.querySelector('.tpl-rec-type').value,
                    value: value,
                    ttl: parseInt(row.querySelector('.tpl-rec-ttl').value) || 3600,
                    prio: parseInt(row.querySelector('.tpl-rec-prio').value) || 0
                });
            }
        });

        if (records.length === 0) {
            FOSSBilling.message('At least one record is required.', 'error');
            return;
        }

        API.admin.post('openprovider/template_create', {
            name: name,
            records: JSON.stringify(records)
        }, function() {
            FOSSBilling.message('Template created.');
            bootstrap.Modal.getInstance(document.getElementById('createTemplateModal')).hide();
            document.getElementById('tpl-name').value = '';
            loadTemplates();
        });
    });
});

function attachRemoveHandlers() {
    document.querySelectorAll('.remove-tpl-row').forEach(function(btn) {
        btn.addEventListener('click', function() {
            if (document.querySelectorAll('.tpl-record-row').length > 1) {
                this.closest('.tpl-record-row').remove();
            }
        });
    });
}

function loadTemplates() {
    API.admin.post('openprovider/template_get_list', {}, function(result) {
        var container = document.getElementById('template-list');
        var templates = result.results || [];

        if (templates.length === 0) {
            container.innerHTML = '<p class="text-muted">No templates found. Create one to get started.</p>';
            return;
        }

        var html = '';
        templates.forEach(function(tpl) {
            html += '<div class="card mb-2"><div class="card-body p-3">';
            html += '<div class="d-flex justify-content-between align-items-center mb-2">';
            html += '<h6 class="mb-0">' + tpl.name + '</h6>';
            html += '<button class="btn btn-sm btn-outline-danger delete-tpl-btn" data-id="' + tpl.id + '" data-name="' + tpl.name + '">Delete</button>';
            html += '</div>';

            if (tpl.records && tpl.records.length > 0) {
                html += '<table class="table table-sm table-borderless mb-0"><thead><tr><th>Name</th><th>Type</th><th>Value</th><th>TTL</th><th>Prio</th></tr></thead><tbody>';
                tpl.records.forEach(function(rec) {
                    html += '<tr><td>' + (rec.name || '(root)') + '</td><td><span class="badge bg-primary">' + rec.type + '</span></td><td>' + rec.value + '</td><td>' + rec.ttl + '</td><td>' + (rec.prio || 0) + '</td></tr>';
                });
                html += '</tbody></table>';
            }

            html += '</div></div>';
        });

        container.innerHTML = html;

        document.querySelectorAll('.delete-tpl-btn').forEach(function(btn) {
            btn.addEventListener('click', function() {
                if (confirm('Delete template "' + this.dataset.name + '"?')) {
                    API.admin.post('openprovider/template_delete', {id: this.dataset.id}, function() {
                        FOSSBilling.message('Template deleted.');
                        loadTemplates();
                    });
                }
            });
        });
    });
}
</script>
{% endblock %}
